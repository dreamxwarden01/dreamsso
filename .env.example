# Copy to .env and edit. .env is gitignored.
#
# You don't have to fill this in by hand: start the SSO unconfigured and the
# first-run /setup wizard collects these values, generates KEY_ENCRYPTION_KEY,
# and writes .env for you. This file is the manual path (and the reference).

# --- docker-compose Postgres ---
POSTGRES_DB=dreamsso
POSTGRES_USER=dreamsso
POSTGRES_PASSWORD=change-me-locally

# --- migration script (node-postgres reads these PG* vars) ---
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=dreamsso
PGPASSWORD=change-me-locally
PGDATABASE=dreamsso

# --- SSO app ---
PORT=3000
# Public issuer origin. Baked into every token + the OIDC discovery document,
# so it can't change after setup without invalidating live tokens. No trailing slash.
ISSUER=https://sso-dev.dreamxwarden.ca
DATABASE_URL=postgresql://dreamsso:dreamsso@127.0.0.1:5432/dreamsso
REDIS_URL=redis://127.0.0.1:6379
NODE_ENV=development
# 32 bytes hex — generate with: openssl rand -hex 32
KEY_ENCRYPTION_KEY=

# --- WebAuthn / passkeys ---
# RP ID = registrable domain (passkeys work across sso/account/stream subdomains).
# Origins = first-party app origin(s) that register passkeys (comma-separated).
WEBAUTHN_RP_ID=dreamxwarden.ca
WEBAUTHN_RP_NAME=DreamSSO
WEBAUTHN_ORIGINS=https://account-dev.dreamxwarden.ca

# --- Account portal (the BFF the SSO points end users to) ---
# ACCOUNT_PORTAL_URL is also editable later from Admin -> Settings.
ACCOUNT_CLIENT_ID=account
ACCOUNT_PORTAL_URL=https://account-dev.dreamxwarden.ca
