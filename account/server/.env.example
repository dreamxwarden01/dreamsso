# Copy to .env — or leave it out entirely and let the first-run wizard at /setup
# write it for you. .env, .account-client-key.json, .mtls.json and .setup-token
# are all gitignored.
#
# The wizard asks for only the three values marked [wizard]. It DERIVES the
# redirect / post-logout / key / event endpoints from PUBLIC_URL, and mints the
# OIDC client key itself (the SSO reads the public half from the key endpoint).

PORT=4001
NODE_ENV=development

# [wizard] This portal's own public https origin.
PUBLIC_URL=https://account-dev.dreamxwarden.ca

# [wizard] The DreamSSO OP (front + back channel).
SSO_ISSUER=https://sso-dev.dreamxwarden.ca
# SSO_INTERNAL=                 # back-channel base if different from the issuer

# [wizard] Sessions live here. The portal has no database of its own.
REDIS_URL=redis://127.0.0.1:6379

# Derived from PUBLIC_URL by the wizard — set these yourself only if you're not
# using it. OIDC_CLIENT_ID must match the client the SSO registers (`account`).
OIDC_CLIENT_ID=account
OIDC_REDIRECT_URI=https://account-dev.dreamxwarden.ca/auth/callback
OIDC_POST_LOGOUT_REDIRECT=https://account-dev.dreamxwarden.ca/
OIDC_CLIENT_KEY_FILE=./.account-client-key.json

SESSION_TTL_SECONDS=28800
# SPA_DIST=                     # defaults to ../client/dist
